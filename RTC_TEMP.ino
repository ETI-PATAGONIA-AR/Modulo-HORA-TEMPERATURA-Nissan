///////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////

void setup() 
{
pinMode (tempPin,INPUT);
display.begin(SSD1306_SWITCHCAPVCC, 0x3C); //Iniciar display OLED
display.clearDisplay();
display.drawBitmap(0,0,logo_nissan1logoNISSAN,128,32,WHITE);

display.setCursor(70,3);
display.setTextSize(1);
display.setTextColor(BLACK);
display.print("Club");

display.setCursor(75,13);
display.print("NISSAN");
display.setCursor(80,23);
display.print("4x4");

display.display();
delay (1500);
display.clearDisplay();
}

///////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////

void loop() 
{
RTC.read(tm);
display.setTextSize(1);
display.setTextColor(WHITE);
display.setCursor(5,0);     
display.print(tm.Hour);    //imprimimos hora
display.print(":");
display.print(tm.Minute);  //imprimimos minutos
display.print(":");
display.print(tm.Second);  //imprimimos segundos
display.setCursor(65,0);
display.print(tm.Day);     //imprimimos dia
display.print('/');
display.print(tm.Month);  //imprimimos mes
display.print('/');
display.print(tmYearToCalendar(tm.Year));    //imprimimos año

vout=analogRead(tempPin);   // Lectura analogica del puerto A0
vout=(vout*500)/1023;
tempc=vout;
display.setCursor(5,12);
display.print("Temperatura:");
display.print(tempc);     //imprimimos temperatura   
display.setCursor(15,24);
display.print("Club NISSAN 4x4");
display.display();
delay(1000);
display.clearDisplay();  //limpiamos display
}
